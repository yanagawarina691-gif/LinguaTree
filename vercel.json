{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "public",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://linguatree-backend.onrender.com/api/$1"
    },
    {
      "source": "/health",
      "destination": "https://linguatree-backend.onrender.com/health"
    }
  ]
}
