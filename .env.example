# ========== LinguaTree Backend 环境配置 ==========

# 服务端口
PORT=3000
NODE_ENV=development

# JWT 密钥
JWT_SECRET=linguatree-demo-secret-2026

# ========== LLM + VLM 配置（OpenAI 兼容接口）==========
# 通义千问 DashScope（国内直连，无需代理）
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
VLM_MODEL=qwen-vl-max

# ========== ASR 语音识别配置 ==========
# provider: 'dashscope' (通义千问 Paraformer, 国内直连) 或 'openai' (Whisper, 需代理)
ASR_PROVIDER=dashscope
ASR_MODEL=paraformer-v2

# DashScope 原生 API（ASR 使用，非 OpenAI 兼容接口）
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxx
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com

# ========== 视频处理 ==========
TEMP_DIR=./temp
MAX_VIDEO_DURATION=300
KEYFRAME_COUNT=5

# ========== 超时设置 ==========
ASR_TIMEOUT=120000
LLM_TIMEOUT=30000
PIPELINE_TIMEOUT=180000

# ========== 代理（可选，仅用 OpenAI 时需要）==========
# HTTP_PROXY=http://127.0.0.1:7897
# HTTPS_PROXY=http://127.0.0.1:7897
